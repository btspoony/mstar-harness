{
  "name": "morning-star",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "packages/opencode/src/mstar.ts",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "postinstall": "bun run opencode:bundle-assets",
    "opencode:bundle-assets": "bun run --cwd packages/opencode bundle-assets",
    "typecheck": "bunx tsc --pretty false",
    "cli:dev": "MSTAR_CLI_PROJECT_ROOT=$PWD bun run --cwd packages/cli dev",
    "cli:build": "bun run --cwd packages/cli build",
    "cli:publish:dry-run": "npm publish --workspace @mstar-harness/cli --dry-run",
    "cli:publish": "npm publish --workspace @mstar-harness/cli",
    "opencode:build": "bun run --cwd packages/opencode build",
    "opencode:publish:dry-run": "npm publish --workspace @mstar-harness/opencode --dry-run",
    "opencode:publish": "npm publish --workspace @mstar-harness/opencode"
  },
  "packageManager": "bun@1.2.17",
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
